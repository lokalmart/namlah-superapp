NEXT_PUBLIC_APP_NAME=Namlah Superapp

# Odoo bridge credentials stay on the Next.js server only.
# Do not prefix these with NEXT_PUBLIC_.
ODOO_URL=https://your-odoo-domain.odoo.com
ODOO_DB=namlah-prod
ODOO_USERNAME=namlah.integration.service@example.com
ODOO_PASSWORD=your-odoo-password-or-json2-api-key
ODOO_API_MODE=xmlrpc
IMPORT_DEFAULT_MODULE=namlah_studio

# Live read mode for Ratu Semut dashboard.
NAMLAH_BRIDGE_LIVE=false

# Keep writes off until /api/odoo/schema-audit is green.
NAMLAH_BRIDGE_WRITES=false
NAMLAH_BRIDGE_SECRET=change-this-long-random-token
